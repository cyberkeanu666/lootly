# Instagram Meta Graph API Credentials (optional — bio-code mode works without)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
HOST_INSTAGRAM_ACCESS_TOKEN=
HOST_INSTAGRAM_ACCOUNT_ID=

# Firebase (primary persistence per lootly-docs)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# BullMQ + Redis (bio scrape queue; omit for inline dev processing)
REDIS_URL=redis://127.0.0.1:6379

# Puppeteer / RapidAPI fallback scraper
RAPIDAPI_KEY=
RAPIDAPI_INSTAGRAM_HOST=instagram-scraper-api2.p.rapidapi.com
SCRAPER_SANDBOX=true
DISABLE_IP_RATE_LIMIT=false
MAX_IP_USERNAMES_PER_GIVEAWAY_PER_DAY=3

# Server
PORT=3000
